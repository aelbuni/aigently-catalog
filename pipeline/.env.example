# Copy to pipeline/.env and fill in your values

# PostgreSQL — matches docker-compose.yml at repo root (port 5433)
DATABASE_URL=postgresql://aigently:aigently@localhost:5433/aigently

# ── Required for: amplify:threats, summarize:rules ────────────────────────────
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Required for sync:threats GHSA source ────────────────────────────────────
# A GitHub PAT with read:packages scope
# In CI this is provided automatically as GITHUB_TOKEN
# Locally: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Optional — 10x faster NVD rate limit (0.65 s vs 6.5 s per request) ───────
# Register free at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
